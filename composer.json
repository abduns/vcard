{
    "name": "abduns/vcard",
    "description": "A framework-agnostic VCard 3.0/4.0 generator for PHP 8.2+.",
    "type": "library",
    "license": "MIT",
    "keywords": [
        "vcard",
        "contact",
        "vcf"
    ],
    "authors": [
        {
            "name": "Abduns",
            "email": "abduns@example.com"
        }
    ],
    "require": {
        "php": "^8.2"
    },
    "require-dev": {
        "friendsofphp/php-cs-fixer": "^3.64",
        "pestphp/pest": "^3.0",
        "phpstan/phpstan": "^2.0"
    },
    "autoload": {
        "psr-4": {
            "Dunn\\VCard\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Dunn\\VCard\\Tests\\": "tests/"
        }
    },
    "scripts": {
        "test": "@php ./vendor/bin/pest",
        "stan": "phpstan analyse --memory-limit=512M",
        "fix": "php-cs-fixer fix",
        "lint": "php-cs-fixer fix --dry-run --diff",
        "ci": [
            "@lint",
            "@stan",
            "@test"
        ]
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}